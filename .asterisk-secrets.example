# .asterisk-secrets — Asterisk Passwörter (nicht in git, nicht committen)
# Kopieren nach .asterisk-secrets und Passwörter eintragen:
#   cp .asterisk-secrets.example .asterisk-secrets

# [dusnet-auth] → dus.net SIP-Anbieter
DUSNET_AUTH_PASSWORD=CHANGEME

# [fritzbox] → Fritz!Box SIP-Auth (falls konfiguriert)
FRITZBOX_PASSWORD=CHANGEME

# [vodafone-auth] → Vodafone SIP-Trunk (falls konfiguriert)
VODAFONE_AUTH_PASSWORD=CHANGEME
