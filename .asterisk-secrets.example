# .asterisk-secrets — Asterisk passwords (not in git, do not commit)
# Copy to .asterisk-secrets and fill in real values:
#   cp .asterisk-secrets.example .asterisk-secrets

# [dusnet-auth] — dus.net SIP provider
DUSNET_AUTH_PASSWORD=CHANGEME

# [fritzbox] — Fritz!Box SIP auth (if configured)
FRITZBOX_AUTH_PASSWORD=CHANGEME

# [vodafone-auth] — Vodafone SIP trunk (if configured)
VODAFONE_AUTH_PASSWORD=CHANGEME
